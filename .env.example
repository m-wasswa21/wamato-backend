# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME=Wamato API
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=development

# ── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=4

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://wamato:wamato@localhost:5432/wamato_db

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Security ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://wamatoestatesmanagementuganda.online,https://backend.wamatoestatesmanagementuganda.online,http://localhost:3000,http://localhost:8080

# ── File Uploads ─────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# ── Cloudinary (optional — leave empty to use local storage) ─────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── MTN Mobile Money ─────────────────────────────────────────────────────────
MTN_MOMO_URL=https://sandbox.momodeveloper.mtn.com
MTN_MOMO_PRIMARY_KEY=
MTN_MOMO_API_USER=
MTN_MOMO_API_KEY=
MTN_MOMO_ENV=sandbox

# ── Admin ────────────────────────────────────────────────────────────────────
FIRST_ADMIN_EMAIL=admin@wamato.ug
FIRST_ADMIN_PASSWORD=Admin@1234!
